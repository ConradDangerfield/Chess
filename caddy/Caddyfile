chess.conraddangerfield.com {
	# Discord embedding headers
	header {
		Content-Security-Policy "frame-ancestors https://discord.com https://*.discord.com https://*.discordsays.com"
		-X-Frame-Options
	}

	# Discord Activity SDK proxy mapping
	handle /.proxy/api/* {
		uri strip_prefix /.proxy
		reverse_proxy backend:8001
	}

	# API + Socket.IO → backend
	handle /api/* {
		reverse_proxy backend:8001
	}

	handle /api/socket.io/* {
		reverse_proxy backend:8001
	}

	# Everything else → frontend
	handle {
		reverse_proxy frontend:80
	}
}
